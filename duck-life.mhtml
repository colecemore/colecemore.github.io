@charset "utf-8";

:root { --desc: #f1f1f1; }

ins.adsbygoogle[data-ad-status=3D"unfilled"] { display: none !important; }

.content-wrapper { margin: 15vh auto 0px; width: 1366px; padding-top: 3%; b=
order-top-left-radius: 25px; border-top-right-radius: 25px; background: rgb=
a(121, 121, 121, 0.35); box-shadow: rgba(0, 0, 0, 0.24) 0px 6px 12px 0px; }

.main-content { margin: 0px 5%; }

.content { position: relative; margin: auto; display: grid; overflow: hidde=
n; justify-content: center; grid-template-columns: 1fr 1fr; }

.content-container { display: flex; flex-direction: column; }

.content iframe, #ruffle { width: 900px; height: 600px; border: none; overf=
low: hidden; background-image: url("/assets/img/preloader.gif"); background=
-position: center center; background-repeat: no-repeat; background-color: r=
gb(19, 18, 18); }

.content .game-wrap { width: 900px; height: 600px; border: none; overflow: =
hidden; }

.content-controls { background: black; margin: 1rem auto; height: 20px; }

.desc { margin: 5% 0px; padding: 2rem; background-color: var(--ubg); border=
-radius: 10px; box-shadow: rgba(0, 0, 0, 0.24) 0px 6px 12px 0px; }

.bar { display: flex; justify-content: space-between; align-items: center; =
background-color: var(--ubg); padding: 0.2rem 2rem 0.75rem; border-bottom-l=
eft-radius: 10px; border-bottom-right-radius: 10px; }

.bar > button { cursor: pointer; width: 2rem; height: 2rem; background-colo=
r: transparent; border-radius: 25px; color: white; border: none; display: f=
lex; align-items: center; justify-content: center; }

.bar-left { display: flex; flex-direction: column; justify-content: center;=
 }

.bar h1 { font-size: 2rem; }

#content-creator { font-size: 1rem; font-style: italic; font-weight: 600; }

#content-desc { color: var(--desc); }

#content-controls { list-style-type: none; }

.othergames-header { font-size: 30px; text-align: center; }

.othergames-hr { width: 250px; margin: 0.5rem auto 1rem; }

@media (max-width: 1024px) {
  .othergames-hr { width: 200px; }
}

@media (max-width: 768px) {
  .othergames-header { font-size: 15px; }
  .othergames-hr { width: 75px; }
}

.og-wrap { position: relative; display: grid; grid-template-rows: repeat(au=
to-fit, 250px); grid-auto-flow: row; gap: 20px; justify-content: center; ma=
rgin: 0px auto; font-size: 75%; }

@media (max-width: 812px) {
  .og-wrap { grid-template-rows: repeat(auto-fit, 150px); gap: 10px; font-s=
ize: 50%; }
}

.og-item { margin-left: auto; margin-right: auto; width: 100%; max-width: 2=
50px; position: relative; border-radius: 5px; color: black; background-colo=
r: rgb(216, 216, 216); transition: box-shadow 0.5s ease-out 0s, transform 0=
.5s ease-out 0s; }

.og-item:hover { background-color: rgb(216, 216, 216); transition: all 0.3s=
 ease 0s; box-shadow: rgba(0, 0, 0, 0.3) 3px 3px 3px; transform: translateY=
(-5px); }

.img-container { position: relative; overflow: hidden; border-radius: 5px 5=
px 0px 0px; }

.og-item img { width: 100%; height: 166.75px; object-fit: cover; cursor: po=
inter; transition: all 0.9s ease 0s; }

@media (max-width: 812px) {
  .og-item img { height: 83.375px; }
}

.img-adjust-1 { object-position: 0px center; }

.img-adjust-2 { object-position: 100% 100%; }

.grid-card-text { padding: 10px; line-height: 5px; }

@media (max-width: 812px) {
  .grid-card-text { padding-top: 5px; padding-left: 5px; padding-right: 5px=
; line-height: 3.3px; }
}

.game-name { font-size: 17px; font-weight: 600; line-height: 1.2em; }

@media (max-width: 812px) {
  .game-name { font-size: 10px; line-height: 1.5em; margin-bottom: 8px; }
}

.game-developer { font-size: 15px; line-height: 20px; font-style: italic; f=
ont-weight: 500; }

@media (max-width: 812px) {
  .game-developer { height: 30px; font-size: 10px; line-height: 1.5em; }
}

.img-container { position: relative; }

.img-container img { display: block; }
